node_modules/

# Контент и overlay — вне git: репозиторий хранит только приложение и стек.
#   data/    — архив (HTML+картинки) + articles.json/index.json (правит апдейтер)
#   overlay/ — изменяемый слой правок (annotations/<id>.json, reviews.json)
# Оба монтируются томами на сервере (CONTENT_DIR / OVERLAY_DIR).
data/
overlay/

# предсжатые ассеты (npm run build) — gzip_static, регенерируются
*.gz

# временные файлы проверки/сборки
.verify/
_*.mjs
_extracted/

# локальные настройки Claude Code
.claude/settings.local.json

# системное
.DS_Store
Thumbs.db
*.log
