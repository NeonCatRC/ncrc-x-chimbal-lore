# Скопируй в deploy/.env и подставь свои значения.
# docker compose читает deploy/.env автоматически (файл рядом с compose).
# .env в git НЕ коммитится (см. .gitignore) — там могут быть секреты.

# --- Какие сервисы поднимать ---
# web стартует всегда. admin-api и updater — за профилями (не стартуют при
# обычном `up`). Раскомментируй, чтобы `docker compose up -d` поднимал все три:
# COMPOSE_PROFILES=admin,updater

# --- Тома на хосте (обязательно для прода) ---
# Каталог с архивом: articles.json, reviews нет тут, articles/<slug>/...
CONTENT_DIR=/srv/chimbal/data
# Каталог со слоем правок: reviews.json, tags.json, annotations/<id>.json
OVERLAY_DIR=/srv/chimbal/overlay

# --- admin-api (правки комментариев/разборов/тегов) ---
# Bearer-токен. ВНИМАНИЕ: фронт сейчас токен НЕ шлёт — если задать, кнопки
# «Сохранить» в UI упадут в 401 (фолбэк на экспорт). Оставь пустым, пока не
# добавлена отправка токена во фронт. Защита и так есть: admin-api на 127.0.0.1.
ADMIN_TOKEN=
# CORS-origin для admin-api (по умолчанию любой; сервис всё равно на localhost).
ADMIN_ALLOW_ORIGIN=*
